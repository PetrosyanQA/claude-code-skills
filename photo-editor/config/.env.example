# Photo Editor — запросы идут через https://mpstats.io/api/big_data/proxy/v1/...
# с заголовком X-Mpstats-TOKEN.

PHOTO_EDITOR_BASE_URL=https://mpstats.io/api/big_data/proxy
PHOTO_EDITOR_TOKEN=your_token_here

# Куда складывать результаты. Дефолт: ~/.claude/output/photo-editor/
# PHOTO_EDITOR_OUTPUT_DIR=
